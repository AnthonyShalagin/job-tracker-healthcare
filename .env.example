# Database (auto-set by Vercel when Prisma Postgres is connected)
DATABASE_URL=

# Auth secret for cron endpoint (generate with: openssl rand -hex 32)
CRON_SECRET=

# Resend API key for email notifications (from https://resend.com/api-keys)
RESEND_API_KEY=

# App URL (your Vercel deployment URL)
NEXT_PUBLIC_APP_URL=https://job-tracker-healthcare.vercel.app
